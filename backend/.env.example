# ---- Qwen Cloud / Alibaba Cloud Model Studio (DashScope) ----
# Create a key at https://dashscope.console.aliyun.com  (or the Model Studio console for your region)
DASHSCOPE_API_KEY=sk-your-key-here

# OpenAI-compatible base URL. Pick the endpoint for your region:
#   US (Virginia):     https://dashscope-us.aliyuncs.com/compatible-mode/v1
#   Singapore:         https://<WorkspaceId>.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
#   China (Beijing):   https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1

# Reasoning / agent model and embedding model
QWEN_MODEL=qwen3.7-max
QWEN_EMBED_MODEL=text-embedding-v4
QWEN_EMBED_DIM=1024

# Set to 1 to run fully offline with a deterministic mock (no API calls). Great for dev + CI.
MNEMO_OFFLINE=0

# ---- Memory store ----
# postgres | memory   (memory = in-process numpy store, no DB needed)
MNEMO_STORE=memory
# Alibaba Cloud RDS for PostgreSQL (pgvector). Used only when MNEMO_STORE=postgres.
DATABASE_URL=postgresql://mnemo:mnemo@localhost:5432/mnemo

# ---- Consolidation ("Dreaming") ----
# How many new episodes trigger an auto-consolidation pass.
CONSOLIDATION_EVERY=8
# Half-life (in days) governing memory decay.
MEMORY_HALF_LIFE_DAYS=30
